# =============================================================================
# Ghostty Configuration
# =============================================================================

# --- Font Configuration ---
font-family = "Monaspace Neon NF"
font-size = 14
font-thicken = true
font-thicken-strength = 40
adjust-cell-width = -1
# Adds vertical breathing room
adjust-cell-height = 10%

# --- Theme ---
# Automatically switches based on macOS appearance
theme = light:Catppuccin Latte,dark:Catppuccin Mocha
window-theme = dark

# --- Window Settings ---
fullscreen = true
window-padding-x = 10
window-padding-y = 10
window-decoration = true
window-save-state = always

# --- Aesthetics ---
background-opacity = 0.95
background-blur = true
# Use 'hidden' for a cleaner look or 'tabs' for native tab bar
macos-titlebar-style = hidden
unfocused-split-opacity = 0.8

# --- Clipboard ---
copy-on-select = clipboard

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true

# --- Performance & Behavior ---
mouse-hide-while-typing = true
confirm-close-surface = false
shell-integration-features = cursor,sudo
# Limit FPS to save battery (60 is smooth, default is often higher/uncapped)
refresh-rate = 60
# Increase scrollback buffer (lines)
scrollback-limit = 100000

# --- Keybindings ---
# Toggle Quick Terminal (Global)
keybind = global:super+grave_accent=toggle_quick_terminal

# Navigation & Search
keybind = super+f=start_search
keybind = super+g=navigate_search:next
keybind = super+shift+g=navigate_search:previous

# Split Management (Arrow keys for navigation)
keybind = super+up=goto_split:top
keybind = super+down=goto_split:bottom
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right

# Split Management (Alternative VIM-style)
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:bottom
keybind = super+alt+k=goto_split:top
keybind = super+alt+l=goto_split:right

# Split Creation
keybind = super+backslash=new_split:right
keybind = super+shift+backslash=new_split:right
keybind = super+shift+minus=new_split:down

# Font Size Controls
keybind = super+equal=increase_font_size
keybind = super++=increase_font_size
keybind = super+minus=decrease_font_size
keybind = super+zero=reset_font_size

# Surface & Pane management
keybind = super+shift+backspace=close_surface
keybind = super+shift+f=toggle_split_zoom

# Tab Management
keybind = super+t=new_tab
keybind = super+alt+o=toggle_tab_overview
keybind = super+shift+[=previous_tab
keybind = super+shift+]=next_tab

# --- Updates ---
# Use 'stable' channel for reliable releases (search is now in stable)
auto-update-channel = stable
auto-update = download
